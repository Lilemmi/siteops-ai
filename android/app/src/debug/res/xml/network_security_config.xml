<?xml version="1.0" encoding="utf-8"?>
<!-- Debug builds may talk to Metro over LAN cleartext; release uses the main config (HTTPS only). -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
